<% layout("layouts/boilerplate") %>

<div class="container mt-5">
  <h3>Edit Review</h3>

  <form 
    method="POST" 
    action="/listings/<%= id %>/reviews/<%= review._id %>?_method=PUT"
    class="needs-validation"
    novalidate
  >
    <div class="mb-3">
      <label for="author" class="form-label">Your Name:</label>
      <input 
        type="text" 
        id="author" 
        name="review[author]" 
        value="<%= review.author %>"
        class="form-control" 
        required
      >
      <div class="invalid-feedback">
        Please enter your name.
      </div>
    </div>

    <div class="mb-3">
      <label for="rating" class="form-label">Rating:</label>
      <input 
        type="range" 
        min="1" 
        max="5" 
        id="rating" 
        name="review[rating]" 
        value="<%= review.rating %>"
        class="form-range"
      >
    </div>

    <div class="mb-3">
      <label for="comment" class="form-label">Comment:</label>
      <textarea 
        id="comment" 
        name="review[comment]" 
        rows="4" 
        class="form-control" 
        required
      ><%= review.comment %></textarea>

      <div class="invalid-feedback">
        Please submit some comments for review.
      </div>
    </div>

    <button class="btn btn-dark">Update Review</button>
  </form>
</div>